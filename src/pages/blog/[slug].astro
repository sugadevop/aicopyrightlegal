---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArticles, getArticleBySlug } from '../../lib/api.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map(article => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect('/blog');
}

// Configure marked for better output
marked.setOptions({
  breaks: false,
  gfm: true,
});

const htmlContent = marked(article.content || '');

// Calculate word count for schema
const wordCount = (article.content || '').split(/\s+/).length;
---

<BaseLayout
  title={article.seo_title || article.title}
  description={article.seo_description || article.excerpt}
  ogImage={article.featured_image || '/og-default.png'}
  type="article"
  publishedDate={article.published_at}
>
  <!-- Article Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": article.title,
    "description": article.excerpt,
    "datePublished": article.published_at,
    "dateModified": article.updated_at || article.published_at,
    "wordCount": wordCount,
    "publisher": {
      "@type": "Organization",
      "name": "AI Copyright Legal",
      "url": "https://aicopyrightlegal.com"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://aicopyrightlegal.com/blog/${article.slug}`
    }
  })} />

  <article class="min-h-screen">
    <!-- Article Header -->
    <header class="bg-gradient-to-b from-slate-50 to-white border-b border-slate-100">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 md:py-14">
        <!-- Breadcrumb (WCAG: nav landmark with aria-label) -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-text-muted" role="list">
            <li><a href="/" class="hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 rounded">Home</a></li>
            <li aria-hidden="true" class="text-slate-300">›</li>
            <li><a href="/blog" class="hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 rounded">News</a></li>
            <li aria-hidden="true" class="text-slate-300">›</li>
            <li aria-current="page" class="text-text font-medium truncate max-w-[200px] sm:max-w-none">{article.title}</li>
          </ol>
        </nav>

        <!-- Meta info -->
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class={`px-2.5 py-1 rounded-md text-xs font-semibold ${
            article.category === 'Court Ruling' ? 'bg-red-100 text-red-800' :
            article.category === 'Regulation' ? 'bg-purple-100 text-purple-800' :
            article.category === 'Settlement' ? 'bg-amber-100 text-amber-800' :
            article.category === 'Guide' ? 'bg-green-100 text-green-800' :
            'bg-blue-100 text-blue-800'
          }`} role="doc-subtitle">{article.category}</span>
          <time datetime={article.published_at} class="text-sm text-text-muted">
            {new Date(article.published_at || article.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          {article.read_time && (
            <span class="text-sm text-text-muted flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {article.read_time} read
            </span>
          )}
        </div>

        <!-- Title -->
        <h1 class="font-heading text-3xl sm:text-4xl md:text-[2.75rem] font-extrabold text-text leading-[1.2] tracking-tight">
          {article.title}
        </h1>

        <!-- Excerpt -->
        {article.excerpt && (
          <p class="mt-5 text-lg sm:text-xl text-text-muted leading-relaxed font-normal">
            {article.excerpt}
          </p>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    {article.featured_image && (
      <figure class="max-w-4xl mx-auto px-4 sm:px-6 -mt-2 mb-10">
        <img
          src={article.featured_image}
          alt={`Featured image for: ${article.title}`}
          class="w-full rounded-xl border border-slate-200 shadow-sm"
          loading="eager"
          decoding="async"
        />
      </figure>
    )}

    <!-- Article Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 md:py-10">
      <div
        class="
          prose prose-slate
          prose-lg
          max-w-none

          /* Typography - readable line length & spacing */
          prose-p:text-[1.0625rem]
          prose-p:leading-[1.8]
          prose-p:text-slate-700
          prose-p:mb-6

          /* Headings - clear hierarchy */
          prose-headings:font-heading
          prose-headings:font-bold
          prose-headings:text-text
          prose-headings:scroll-mt-20

          prose-h2:text-2xl
          prose-h2:sm:text-[1.75rem]
          prose-h2:mt-12
          prose-h2:mb-5
          prose-h2:pb-3
          prose-h2:border-b
          prose-h2:border-slate-200

          prose-h3:text-xl
          prose-h3:mt-8
          prose-h3:mb-4

          prose-h4:text-lg
          prose-h4:mt-6
          prose-h4:mb-3

          /* Links - accessible contrast */
          prose-a:text-primary
          prose-a:font-medium
          prose-a:underline
          prose-a:underline-offset-2
          prose-a:decoration-primary/40
          hover:prose-a:decoration-primary

          /* Lists - readable spacing */
          prose-li:text-[1.0625rem]
          prose-li:leading-[1.8]
          prose-li:text-slate-700
          prose-li:mb-2

          prose-ul:my-6
          prose-ol:my-6

          /* Strong/Bold */
          prose-strong:text-slate-900
          prose-strong:font-semibold

          /* Blockquotes - visually distinct */
          prose-blockquote:border-l-4
          prose-blockquote:border-primary
          prose-blockquote:bg-blue-50/60
          prose-blockquote:rounded-r-lg
          prose-blockquote:py-3
          prose-blockquote:px-5
          prose-blockquote:not-italic
          prose-blockquote:text-slate-700
          prose-blockquote:my-8

          /* Code blocks */
          prose-code:text-sm
          prose-code:bg-slate-100
          prose-code:px-1.5
          prose-code:py-0.5
          prose-code:rounded
          prose-code:font-mono
          prose-code:before:content-none
          prose-code:after:content-none

          prose-pre:bg-slate-900
          prose-pre:rounded-xl
          prose-pre:shadow-sm
          prose-pre:my-8

          /* Tables - accessible */
          prose-table:my-8
          prose-th:bg-slate-50
          prose-th:text-left
          prose-th:font-semibold
          prose-th:text-slate-700
          prose-td:text-slate-600

          /* Images */
          prose-img:rounded-xl
          prose-img:shadow-sm
          prose-img:border
          prose-img:border-slate-200

          /* HR */
          prose-hr:my-10
          prose-hr:border-slate-200
        "
        set:html={htmlContent}
      />
    </div>

    <!-- Article Footer -->
    <footer class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
      <!-- Disclaimer -->
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 mb-8" role="note" aria-label="Legal disclaimer">
        <p class="text-sm text-text-muted leading-relaxed">
          <strong class="text-slate-700">Disclaimer:</strong> This article is for informational purposes only and does not constitute legal advice. For guidance on your specific situation, consult a qualified attorney.
        </p>
      </div>

      <!-- Share & Navigation -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 py-6 border-t border-slate-200">
        <a href="/blog" class="inline-flex items-center gap-2 text-primary font-medium text-sm hover:underline focus:outline-none focus:ring-2 focus:ring-primary/50 rounded">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to All Articles
        </a>
        <div class="text-xs text-text-muted">
          Last updated: {new Date(article.updated_at || article.published_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </div>
      </div>

      <!-- Newsletter CTA -->
      <div class="bg-gradient-to-br from-primary/5 to-blue-50 rounded-2xl p-6 sm:p-8 mt-8 border border-primary/10">
        <div class="text-center">
          <h2 class="font-heading font-bold text-xl text-text mb-2">Stay Updated on AI Copyright Law</h2>
          <p class="text-sm text-text-muted mb-5 max-w-md mx-auto">Get weekly analysis of new rulings, regulations, and practical guidance delivered to your inbox.</p>
          <form class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              id="newsletter-email"
              type="email"
              placeholder="your@email.com"
              required
              aria-required="true"
              class="flex-1 px-4 py-2.5 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
            />
            <button type="submit" class="px-5 py-2.5 bg-primary text-white font-semibold rounded-lg text-sm hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
              Subscribe
            </button>
          </form>
          <p class="text-xs text-text-muted mt-3">No spam. Unsubscribe anytime.</p>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>
