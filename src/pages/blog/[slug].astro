---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArticles, getArticleBySlug } from '../../lib/api.js';
import { marked } from 'marked';

// Generate static paths for all published articles
export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map(article => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect('/blog');
}

const htmlContent = marked(article.content || '');
---

<BaseLayout
  title={article.seo_title || article.title}
  description={article.seo_description || article.excerpt}
  ogImage={article.featured_image || '/og-default.png'}
  type="article"
  publishedDate={article.published_at}
>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-6">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">›</span>
      <a href="/blog" class="hover:text-primary">News</a>
      <span class="mx-2">›</span>
      <span class="text-text">{article.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class={`px-2 py-0.5 rounded text-xs font-semibold ${
          article.category === 'Court Ruling' ? 'bg-red-50 text-red-700' :
          article.category === 'Regulation' ? 'bg-purple-50 text-purple-700' :
          article.category === 'Settlement' ? 'bg-amber-50 text-amber-700' :
          'bg-blue-50 text-blue-700'
        }`}>{article.category}</span>
        <span class="text-sm text-text-muted">
          {new Date(article.published_at || article.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
        {article.read_time && <span class="text-sm text-text-muted">· {article.read_time} read</span>}
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text leading-tight mb-4">
        {article.title}
      </h1>
      {article.excerpt && (
        <p class="text-lg text-text-muted leading-relaxed">{article.excerpt}</p>
      )}
    </header>

    <!-- Featured Image -->
    {article.featured_image && (
      <img
        src={article.featured_image}
        alt={article.title}
        class="w-full rounded-xl mb-8 border border-slate-200"
        loading="eager"
      />
    )}

    <!-- Content -->
    <div class="prose prose-slate prose-lg max-w-none
      prose-headings:font-heading prose-headings:font-bold
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-relaxed prose-p:text-text-muted
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-strong:text-text
      prose-li:text-text-muted
      prose-blockquote:border-primary prose-blockquote:bg-blue-50/50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
    " set:html={htmlContent} />

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-slate-200">
      <div class="bg-slate-50 rounded-xl p-6 text-center">
        <h3 class="font-heading font-bold text-lg text-text mb-2">Stay Updated on AI Copyright Law</h3>
        <p class="text-sm text-text-muted mb-4">Get weekly analysis of new rulings and regulations.</p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input type="email" placeholder="your@email.com" class="flex-1 px-4 py-2 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
          <button type="submit" class="px-5 py-2 bg-primary text-white font-semibold rounded-lg text-sm hover:bg-primary-dark">Subscribe</button>
        </form>
      </div>

      <div class="mt-8 flex items-center justify-between">
        <a href="/blog" class="text-primary font-medium text-sm hover:underline">← Back to News</a>
        <div class="text-xs text-text-muted">
          Last updated: {new Date(article.updated_at || article.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>
