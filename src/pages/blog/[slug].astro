---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArticles, getArticleBySlug } from '../../lib/api.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map(article => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect('/blog');
}

marked.setOptions({ breaks: false, gfm: true });
const htmlContent = marked(article.content || '');
const wordCount = (article.content || '').split(/\s+/).length;
---

<BaseLayout
  title={article.seo_title || article.title}
  description={article.seo_description || article.excerpt}
  ogImage={article.featured_image || '/og-default.png'}
  type="article"
  publishedDate={article.published_at}
>
  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": article.title,
    "description": article.excerpt,
    "datePublished": article.published_at,
    "dateModified": article.updated_at || article.published_at,
    "wordCount": wordCount,
    "publisher": { "@type": "Organization", "name": "AI Copyright Legal", "url": "https://aicopyrightlegal.com" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": `https://aicopyrightlegal.com/blog/${article.slug}` }
  })} />

  <article class="acl-article">
    <!-- Header -->
    <header class="acl-article-header">
      <div class="acl-container">
        <nav aria-label="Breadcrumb" class="acl-breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{article.title}</span>
        </nav>

        <div class="acl-meta">
          <span class={`acl-category acl-category--${article.category?.toLowerCase().replace(/\s+/g, '-')}`}>
            {article.category}
          </span>
          <time datetime={article.published_at}>
            {new Date(article.published_at || article.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          {article.read_time && <span class="acl-read-time">{article.read_time} read</span>}
        </div>

        <h1 class="acl-title">{article.title}</h1>

        {article.excerpt && (
          <p class="acl-excerpt">{article.excerpt}</p>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    {article.featured_image && (
      <figure class="acl-featured-image">
        <img src={article.featured_image} alt={article.title} loading="eager" />
      </figure>
    )}

    <!-- Content -->
    <div class="acl-container">
      <div class="acl-content" set:html={htmlContent} />
    </div>

    <!-- Footer -->
    <footer class="acl-container acl-article-footer">
      <div class="acl-disclaimer">
        <p><strong>Disclaimer:</strong> This article is for informational purposes only and does not constitute legal advice. Consult a qualified attorney for guidance on your specific situation.</p>
      </div>

      <div class="acl-nav-footer">
        <a href="/blog">← All Articles</a>
        <span class="acl-updated">Updated {new Date(article.updated_at || article.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
      </div>

      <div class="acl-newsletter-cta">
        <h2>Stay Updated on AI Copyright Law</h2>
        <p>Weekly analysis of new rulings, regulations, and practical guidance.</p>
        <form>
          <label for="email-cta" class="sr-only">Email address</label>
          <input id="email-cta" type="email" placeholder="your@email.com" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </footer>
  </article>
</BaseLayout>

<style is:global>
/* ============================================
   AI Copyright Legal — Article Styles
   WordPress-inspired editorial typography
   ============================================ */

.acl-article {
  --content-width: 680px;
  --wide-width: 1080px;
  --font-body: 'Georgia', 'Times New Roman', serif;
  --font-heading: 'Plus Jakarta Sans', -apple-system, sans-serif;
  --font-ui: 'Inter', -apple-system, sans-serif;
  --color-body: #1a1a1a;
  --color-muted: #555;
  --color-light: #767676;
  --color-border: #e0e0e0;
  --color-bg-soft: #f7f7f7;
  --color-accent: #0056b3;
}

/* Container */
.acl-container {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 0 1.25rem;
}

/* Header */
.acl-article-header {
  padding: 2.5rem 0 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}

.acl-breadcrumb {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--color-light);
  margin-bottom: 1.5rem;
}
.acl-breadcrumb a {
  color: var(--color-light);
  text-decoration: none;
}
.acl-breadcrumb a:hover {
  color: var(--color-accent);
  text-decoration: underline;
}
.acl-breadcrumb span[aria-hidden] {
  margin: 0 0.4rem;
  color: #ccc;
}
.acl-breadcrumb [aria-current] {
  color: var(--color-muted);
}

.acl-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--color-light);
}

.acl-category {
  display: inline-block;
  padding: 0.2rem 0.6rem;
  border-radius: 3px;
  font-weight: 600;
  font-size: 0.6875rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  background: #eef4ff;
  color: #1a56db;
}
.acl-category--court-ruling { background: #fef2f2; color: #b91c1c; }
.acl-category--regulation { background: #f3e8ff; color: #7c3aed; }
.acl-category--settlement { background: #fffbeb; color: #b45309; }
.acl-category--guide { background: #ecfdf5; color: #047857; }

.acl-read-time::before {
  content: "·";
  margin-right: 0.75rem;
}

.acl-title {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 5vw, 2.5rem);
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-body);
  margin: 0 0 1rem;
  letter-spacing: -0.02em;
}

.acl-excerpt {
  font-family: var(--font-body);
  font-size: 1.1875rem;
  line-height: 1.6;
  color: var(--color-muted);
  margin: 0;
}

/* Featured Image */
.acl-featured-image {
  max-width: var(--wide-width);
  margin: 0 auto 2.5rem;
  padding: 0 1.25rem;
}
.acl-featured-image img {
  width: 100%;
  height: auto;
  border-radius: 8px;
}

/* ============================================
   Content — WordPress-style editorial
   ============================================ */
.acl-content {
  font-family: var(--font-body);
  font-size: 1.125rem;
  line-height: 1.7;
  color: var(--color-body);
  overflow-wrap: break-word;
  word-wrap: break-word;
}

/* Paragraphs */
.acl-content p {
  margin: 0 0 1.5em;
}

/* Headings */
.acl-content h1,
.acl-content h2,
.acl-content h3,
.acl-content h4 {
  font-family: var(--font-heading);
  font-weight: 700;
  line-height: 1.3;
  color: var(--color-body);
  letter-spacing: -0.01em;
}

.acl-content h2 {
  font-size: 1.625rem;
  margin: 2.5em 0 0.75em;
}

.acl-content h3 {
  font-size: 1.3125rem;
  margin: 2em 0 0.6em;
}

.acl-content h4 {
  font-size: 1.125rem;
  margin: 1.5em 0 0.5em;
}

/* First heading after header needs less top margin */
.acl-content > h2:first-child {
  margin-top: 0;
}

/* Links */
.acl-content a {
  color: var(--color-accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.acl-content a:hover {
  color: #003d80;
}

/* Lists */
.acl-content ul,
.acl-content ol {
  margin: 0 0 1.5em;
  padding-left: 1.5em;
}

.acl-content li {
  margin-bottom: 0.4em;
}

.acl-content li > ul,
.acl-content li > ol {
  margin-top: 0.4em;
  margin-bottom: 0.4em;
}

/* Bold */
.acl-content strong {
  font-weight: 700;
  color: var(--color-body);
}

/* Emphasis */
.acl-content em {
  font-style: italic;
}

/* Blockquotes — subtle, editorial */
.acl-content blockquote {
  margin: 1.75em 0;
  padding: 1em 1.5em;
  border-left: 4px solid var(--color-accent);
  background: var(--color-bg-soft);
  border-radius: 0 6px 6px 0;
  font-style: italic;
  color: var(--color-muted);
}

.acl-content blockquote p:last-child {
  margin-bottom: 0;
}

/* Code — inline */
.acl-content code {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 0.875em;
  background: #f0f0f0;
  padding: 0.15em 0.4em;
  border-radius: 3px;
  word-break: break-all;
}

/* Code — blocks */
.acl-content pre {
  margin: 1.75em 0;
  padding: 1.25em 1.5em;
  background: #1e293b;
  border-radius: 8px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  max-width: 100%;
}

.acl-content pre code {
  background: none;
  padding: 0;
  font-size: 0.8125rem;
  line-height: 1.6;
  color: #e2e8f0;
  word-break: normal;
}

/* Tables — scrollable on mobile */
.acl-content table {
  width: 100%;
  margin: 1.75em 0;
  border-collapse: collapse;
  font-family: var(--font-ui);
  font-size: 0.9375rem;
  display: block;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.acl-content thead {
  border-bottom: 2px solid var(--color-border);
}

.acl-content th {
  text-align: left;
  padding: 0.6em 1em;
  font-weight: 600;
  color: var(--color-body);
  white-space: nowrap;
}

.acl-content td {
  padding: 0.6em 1em;
  border-bottom: 1px solid #f0f0f0;
  color: var(--color-muted);
}

.acl-content tr:last-child td {
  border-bottom: none;
}

/* Images */
.acl-content img {
  max-width: 100%;
  height: auto;
  border-radius: 6px;
  margin: 1.5em 0;
}

/* Horizontal rule */
.acl-content hr {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: 2.5em 0;
}

/* ============================================
   Footer
   ============================================ */
.acl-article-footer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.acl-disclaimer {
  background: var(--color-bg-soft);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  margin-bottom: 2rem;
}
.acl-disclaimer p {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--color-muted);
  margin: 0;
  line-height: 1.6;
}

.acl-nav-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2rem;
}
.acl-nav-footer a {
  font-family: var(--font-ui);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-accent);
  text-decoration: none;
}
.acl-nav-footer a:hover { text-decoration: underline; }
.acl-updated {
  font-family: var(--font-ui);
  font-size: 0.75rem;
  color: var(--color-light);
}

/* Newsletter CTA */
.acl-newsletter-cta {
  background: linear-gradient(135deg, #f0f7ff 0%, #f8f9fa 100%);
  border: 1px solid #e0ecff;
  border-radius: 12px;
  padding: 2rem;
  text-align: center;
  margin-bottom: 3rem;
}
.acl-newsletter-cta h2 {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-body);
  margin: 0 0 0.5rem;
}
.acl-newsletter-cta p {
  font-family: var(--font-ui);
  font-size: 0.875rem;
  color: var(--color-muted);
  margin: 0 0 1.25rem;
}
.acl-newsletter-cta form {
  display: flex;
  gap: 0.5rem;
  max-width: 360px;
  margin: 0 auto;
}
.acl-newsletter-cta input {
  flex: 1;
  padding: 0.6rem 0.875rem;
  border: 1px solid #d0d5dd;
  border-radius: 6px;
  font-size: 0.875rem;
  font-family: var(--font-ui);
}
.acl-newsletter-cta input:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px rgba(0, 86, 179, 0.1);
}
.acl-newsletter-cta button {
  padding: 0.6rem 1.25rem;
  background: var(--color-accent);
  color: white;
  border: none;
  border-radius: 6px;
  font-family: var(--font-ui);
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
}
.acl-newsletter-cta button:hover {
  background: #003d80;
}

/* Responsive */
@media (max-width: 640px) {
  .acl-newsletter-cta form {
    flex-direction: column;
  }
  .acl-content {
    font-size: 1.0625rem;
  }
  .acl-content h2 {
    font-size: 1.375rem;
  }
  .acl-content h3 {
    font-size: 1.1875rem;
  }
  .acl-title {
    font-size: 1.625rem;
  }
  .acl-excerpt {
    font-size: 1.0625rem;
  }
}

/* Screen reader only */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}
</style>
