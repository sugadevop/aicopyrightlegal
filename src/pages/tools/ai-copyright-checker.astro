---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Copyright Risk Checker — Assess Your Legal Risk"
  description="Answer a few questions about how you use AI and get a personalized copyright risk assessment with actionable recommendations."
>
  <section class="max-w-3xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">AI Copyright Risk Checker</h1>
      <p class="text-text-muted text-lg">Answer 6 quick questions to understand your copyright risk level when using AI-generated content.</p>
    </div>

    <!-- Quiz Container -->
    <div id="quiz-container">
      <div id="quiz-progress" class="mb-6">
        <div class="flex items-center justify-between text-sm text-text-muted mb-2">
          <span>Question <span id="current-q">1</span> of 6</span>
          <span id="progress-pct">0%</span>
        </div>
        <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
          <div id="progress-bar" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <div id="quiz-questions" class="bg-white border border-slate-200 rounded-xl p-6 md:p-8">
        <!-- Questions rendered by JS -->
      </div>
    </div>

    <!-- Results (hidden initially) -->
    <div id="quiz-results" class="hidden">
      <div id="result-card" class="bg-white border border-slate-200 rounded-xl p-6 md:p-8">
        <!-- Results rendered by JS -->
      </div>

      <div class="mt-6 text-center">
        <button id="retake-btn" class="px-5 py-2.5 bg-slate-100 text-text font-medium rounded-lg text-sm hover:bg-slate-200 transition-colors">
          ↺ Retake Assessment
        </button>
      </div>

      <div class="mt-8 bg-blue-50 border border-blue-200 rounded-xl p-5">
        <p class="text-sm text-blue-800"><strong>Note:</strong> This tool provides general educational information only. It is not legal advice. For guidance on your specific situation, consult a qualified intellectual property attorney.</p>
      </div>
    </div>
  </section>

  <script>
    const questions = [
      {
        q: "How much of your final content is generated by AI?",
        options: [
          { text: "AI generates everything — I just publish it", score: 3 },
          { text: "AI generates most of it — I make minor edits", score: 2 },
          { text: "AI creates a draft — I substantially rewrite it", score: 1 },
          { text: "I create the content — AI only assists with small tasks", score: 0 },
        ]
      },
      {
        q: "Do you edit or modify the AI output before publishing?",
        options: [
          { text: "No, I publish AI output as-is", score: 3 },
          { text: "Minor edits (typos, formatting)", score: 2 },
          { text: "Significant editing (restructure, add original analysis)", score: 1 },
          { text: "I rewrite extensively — AI output is just a starting point", score: 0 },
        ]
      },
      {
        q: "Do you add original creative elements to the AI output?",
        options: [
          { text: "No, the content is purely AI-generated", score: 3 },
          { text: "I add a few original sentences or tweaks", score: 2 },
          { text: "I add substantial original content, analysis, or creative choices", score: 1 },
          { text: "The majority of creative decisions are mine — AI is just a tool", score: 0 },
        ]
      },
      {
        q: "How do you use the AI-generated content commercially?",
        options: [
          { text: "I sell it or use it as a core product", score: 3 },
          { text: "It's published on my website/social media for business", score: 2 },
          { text: "Internal use only (research, brainstorming)", score: 0 },
          { text: "Personal/non-commercial use", score: 0 },
        ]
      },
      {
        q: "Do you claim copyright or ownership over the AI-generated content?",
        options: [
          { text: "Yes, I claim full copyright", score: 3 },
          { text: "I'm not sure / I haven't thought about it", score: 2 },
          { text: "I only claim copyright on the parts I created", score: 1 },
          { text: "No, I understand AI output may not be copyrightable", score: 0 },
        ]
      },
      {
        q: "Do you disclose your use of AI to your audience?",
        options: [
          { text: "No disclosure", score: 2 },
          { text: "Sometimes, when asked", score: 1 },
          { text: "Yes, I have a clear AI disclosure policy", score: 0 },
          { text: "Yes, I label individual pieces of AI-assisted content", score: 0 },
        ]
      },
    ];

    let currentQuestion = 0;
    let answers = [];

    function renderQuestion() {
      const q = questions[currentQuestion];
      const container = document.getElementById('quiz-questions');
      const progress = ((currentQuestion) / questions.length) * 100;

      document.getElementById('current-q').textContent = currentQuestion + 1;
      document.getElementById('progress-pct').textContent = Math.round(progress) + '%';
      document.getElementById('progress-bar').style.width = progress + '%';

      container.innerHTML = `
        <h2 class="font-heading font-bold text-xl text-text mb-5">${q.q}</h2>
        <div class="space-y-3">
          ${q.options.map((opt, i) => `
            <button onclick="selectAnswer(${i})" class="w-full text-left p-4 border border-slate-200 rounded-lg hover:border-primary hover:bg-blue-50/50 transition-colors text-sm text-text">
              ${opt.text}
            </button>
          `).join('')}
        </div>
      `;
    }

    window.selectAnswer = function(index) {
      answers.push(questions[currentQuestion].options[index].score);
      currentQuestion++;

      if (currentQuestion < questions.length) {
        renderQuestion();
      } else {
        showResults();
      }
    };

    function showResults() {
      const totalScore = answers.reduce((a, b) => a + b, 0);
      const maxScore = questions.length * 3;
      const percentage = (totalScore / maxScore) * 100;

      let level, color, icon, summary, recommendations;

      if (percentage <= 20) {
        level = 'Low Risk';
        color = 'green';
        icon = '✅';
        summary = 'Your use of AI appears to be low-risk from a copyright perspective. You are using AI as a tool while maintaining substantial human creative control.';
        recommendations = [
          'Continue documenting your creative process',
          'Keep records of your human contributions',
          'Consider adding an AI disclosure for transparency',
          'Your work is likely copyrightable based on your human input',
        ];
      } else if (percentage <= 50) {
        level = 'Moderate Risk';
        color = 'amber';
        icon = '⚠️';
        summary = 'Your use of AI carries moderate copyright risk. Some of your content may not qualify for copyright protection, depending on the level of human creative input.';
        recommendations = [
          'Increase your human creative contributions to AI outputs',
          'Document your editing and creative decision-making process',
          'Add a clear AI disclosure to your website',
          'Consider which content you rely on for copyright protection',
          'Avoid claiming copyright on minimally-edited AI output',
        ];
      } else {
        level = 'High Risk';
        color = 'red';
        icon = '🚨';
        summary = 'Your use of AI carries significant copyright risk. Content generated primarily by AI with minimal human input is unlikely to be copyrightable under current U.S. law.';
        recommendations = [
          'Substantially edit and modify AI outputs before publishing',
          'Add original creative elements, analysis, and human judgment',
          'Do not claim copyright on purely AI-generated content',
          'Add a clear AI disclosure statement immediately',
          'Consider consulting an IP attorney about your specific situation',
          'Be aware that competitors can legally copy uncopyrightable AI content',
        ];
      }

      document.getElementById('quiz-container').classList.add('hidden');
      document.getElementById('quiz-results').classList.remove('hidden');

      const colorClasses = {
        green: 'bg-green-50 border-green-200 text-green-800',
        amber: 'bg-amber-50 border-amber-200 text-amber-800',
        red: 'bg-red-50 border-red-200 text-red-800',
      };

      document.getElementById('result-card').innerHTML = `
        <div class="text-center mb-6">
          <div class="text-4xl mb-3">${icon}</div>
          <div class="inline-block px-4 py-1.5 rounded-full text-sm font-bold ${colorClasses[color]} border mb-3">
            ${level}
          </div>
          <div class="text-sm text-text-muted">Score: ${totalScore}/${maxScore}</div>
        </div>

        <p class="text-text leading-relaxed mb-6">${summary}</p>

        <h3 class="font-heading font-bold text-lg text-text mb-3">Recommendations:</h3>
        <ul class="space-y-2 mb-6">
          ${recommendations.map(r => `<li class="flex items-start gap-2 text-sm text-text"><span class="text-primary mt-0.5">→</span> ${r}</li>`).join('')}
        </ul>

        <div class="border-t border-slate-200 pt-5 mt-5">
          <h3 class="font-heading font-bold text-sm text-text mb-2">Want to reduce your risk?</h3>
          <div class="flex flex-wrap gap-2">
            <a href="/learn/can-you-copyright-ai-content" class="px-3 py-1.5 bg-slate-100 text-text text-xs font-medium rounded-lg hover:bg-slate-200">📖 Copyright Guide</a>
            <a href="/tools/ai-disclosure-generator" class="px-3 py-1.5 bg-slate-100 text-text text-xs font-medium rounded-lg hover:bg-slate-200">📝 Create Disclosure</a>
            <a href="/blog" class="px-3 py-1.5 bg-slate-100 text-text text-xs font-medium rounded-lg hover:bg-slate-200">📰 Latest News</a>
          </div>
        </div>
      `;
    }

    // Retake
    document.getElementById('retake-btn').addEventListener('click', () => {
      currentQuestion = 0;
      answers = [];
      document.getElementById('quiz-container').classList.remove('hidden');
      document.getElementById('quiz-results').classList.add('hidden');
      renderQuestion();
    });

    // Init
    renderQuestion();
  </script>
</BaseLayout>
