---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found (404)" description="The page you're looking for doesn't exist or has been moved.">
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="text-6xl mb-6">⚖️</div>
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">Page Not Found</h1>
    <p class="text-text-muted text-lg mb-8">The page you're looking for doesn't exist, has been moved, or is no longer available.</p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
      <a href="/" class="px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors">
        ← Back to Homepage
      </a>
      <a href="/blog" class="px-6 py-3 bg-slate-100 text-text font-semibold rounded-xl hover:bg-slate-200 transition-colors">
        Browse Articles
      </a>
    </div>

    <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 text-left">
      <h2 class="font-heading font-bold text-lg text-text mb-3">Looking for something specific?</h2>
      <ul class="space-y-2 text-sm text-text-muted">
        <li><a href="/blog" class="text-primary hover:underline">📰 Latest AI Copyright News</a></li>
        <li><a href="/cases" class="text-primary hover:underline">⚖️ AI Copyright Lawsuit Tracker</a></li>
        <li><a href="/tools" class="text-primary hover:underline">🔧 Free AI Copyright Tools</a></li>
        <li><a href="/learn" class="text-primary hover:underline">📖 Learn AI Copyright Law</a></li>
        <li><a href="/laws" class="text-primary hover:underline">🌍 Laws by Country</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
